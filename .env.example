# Postgres connection string (Supabase session-mode pooler or direct)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Supabase project URL (used by the API for storage and auth admin calls)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (safe for browser — used by the web app)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service-role key (NEVER expose to browser — Hono API only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
